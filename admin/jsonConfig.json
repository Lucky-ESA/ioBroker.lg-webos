{
    "i18n": true,
    "type": "panel",
    "items": {
        "tab1": {
            "type": "panel",
            "label": "lg-webos adapter settings",
            "newLine": true,
            "items": {
                "_headerAdapter": {
                    "type": "header",
                    "text": "Create devices",
                    "size": 2
                },
                "devices": {
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "noDelete": false,
                    "type": "accordion",
                    "titleAttr": "tvname",
                    "items": [
                        {
                            "type": "checkbox",
                            "attr": "active",
                            "xs": 12,
                            "sm": 12,
                            "md": 12,
                            "lg": 12,
                            "xl": 12,
                            "label": "activ",
                            "tooltip": "activ_tt",
                            "default": false,
                            "style": {
                                "textAlign": "center"
                            }
                        },
                        {
                            "type": "select",
                            "attr": "ws",
                            "xs": 12,
                            "sm": 12,
                            "md": 12,
                            "lg": 12,
                            "xl": 12,
                            "label": "ws",
                            "tooltip": "ws_tt",
                            "options": [
                                { "value": "ws", "label": "WS Connection" },
                                { "value": "wss", "label": "WSS Connection" }
                            ],
                            "default": "wss"
                        },
                        {
                            "type": "select",
                            "attr": "discover",
                            "xs": 12,
                            "sm": 12,
                            "md": 12,
                            "lg": 12,
                            "xl": 12,
                            "label": "discover",
                            "tooltip": "discover_tt",
                            "options": [
                                { "value": "dns", "label": "DNS" },
                                { "value": "dgram", "label": "SSDP" }
                            ],
                            "default": "dns"
                        },
                        {
                            "type": "text",
                            "attr": "tvname",
                            "xs": 12,
                            "sm": 12,
                            "md": 12,
                            "lg": 12,
                            "xl": 12,
                            "label": "name",
                            "tooltip": "name_tt",
                            "default": "Dummy"
                        },
                        {
                            "type": "text",
                            "attr": "ip",
                            "xs": 12,
                            "sm": 12,
                            "md": 12,
                            "lg": 12,
                            "xl": 12,
                            "label": "tvip",
                            "tooltip": "tvip_tt"
                        },
                        {
                            "type": "text",
                            "attr": "mac",
                            "xs": 12,
                            "sm": 12,
                            "md": 12,
                            "lg": 12,
                            "xl": 12,
                            "label": "mac",
                            "tooltip": "mac_tt"
                        },
                        {
                            "type": "number",
                            "attr": "interval",
                            "xs": 12,
                            "sm": 12,
                            "md": 12,
                            "lg": 12,
                            "xl": 12,
                            "label": "interval",
                            "tooltip": "interval_tt",
                            "min": 0,
                            "max": 1440,
                            "step": 1,
                            "default": 0
                        },
                        {
                            "type": "checkbox",
                            "attr": "luna",
                            "xs": 12,
                            "sm": 12,
                            "md": 12,
                            "lg": 12,
                            "xl": 12,
                            "label": "luna",
                            "tooltip": "luna_tt",
                            "default": false
                        },
                        {
                            "type": "checkbox",
                            "attr": "oldDevice",
                            "xs": 12,
                            "sm": 12,
                            "md": 12,
                            "lg": 12,
                            "xl": 12,
                            "label": "old",
                            "tooltip": "old_tt",
                            "default": false
                        },
                        {
                            "type": "checkbox",
                            "attr": "picture",
                            "xs": 12,
                            "sm": 12,
                            "md": 12,
                            "lg": 12,
                            "xl": 12,
                            "label": "pic",
                            "tooltip": "pic_tt",
                            "default": false
                        },
                        {
                            "type": "table",
                            "newLine": true,
                            "attr": "system",
                            "xs": 12,
                            "sm": 12,
                            "md": 12,
                            "lg": 12,
                            "xl": 12,
                            "default": [],
                            "label": "systemSettings",
                            "items": [
                                {
                                    "type": "text",
                                    "attr": "name",
                                    "width": "15% ",
                                    "title": "object_name",
                                    "tooltip": "object_name_tt",
                                    "filter": false,
                                    "sort": false,
                                    "default": "Brightness"
                                },
                                {
                                    "type": "select",
                                    "attr": "category",
                                    "width": "20% ",
                                    "title": "category",
                                    "tooltip": "category_tt",
                                    "filter": false,
                                    "sort": false,
                                    "default": "picture",
                                    "options": [
                                        { "value": "", "label": "EULA" },
                                        { "value": "aiPicturem", "label": "AI Picture" },
                                        { "value": "twinTv", "label": "Twin TV" },
                                        { "value": "network", "label": "Network" },
                                        { "value": "option", "label": "Option" },
                                        { "value": "time", "label": "Time" },
                                        { "value": "picture", "label": "Picture" },
                                        { "value": "other", "label": "Other" },
                                        { "value": "sound", "label": "Sound" },
                                        { "value": "lock", "label": "Lock" },
                                        { "value": "general", "label": "General" }
                                    ]
                                },
                                {
                                    "type": "text",
                                    "attr": "settings",
                                    "width": "15% ",
                                    "title": "settings",
                                    "tooltip": "settings_tt",
                                    "filter": false,
                                    "sort": false,
                                    "default": "brightness"
                                },
                                {
                                    "type": "text",
                                    "attr": "role",
                                    "width": "15% ",
                                    "title": "role_t",
                                    "tooltip": "role_tt",
                                    "filter": false,
                                    "sort": false,
                                    "default": "value.brightness"
                                },
                                {
                                    "type": "text",
                                    "attr": "type",
                                    "width": "15% ",
                                    "title": "type_t",
                                    "tooltip": "type_tt",
                                    "filter": false,
                                    "sort": false,
                                    "default": "number"
                                },
                                {
                                    "type": "jsonEditor",
                                    "attr": "attr",
                                    "width": "20% ",
                                    "title": "attr",
                                    "tooltip": "attr_tt",
                                    "filter": false,
                                    "sort": false,
                                    "default": "{\"step\": 1,\"max\": 100,\"min\": 0,\"def\": 0}"
                                }
                            ]
                        }
                    ]
                }
            }
        }
    }
}
